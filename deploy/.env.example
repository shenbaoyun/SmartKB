# ============================================================
# SmartKB 环境变量模板
# 复制为 .env 并填入真实值：cp .env.example .env
# ============================================================

# ---------- 必填：LLM API Key（DeepSeek 或百炼二选一） ----------
DEEPSEEK_API_KEY=sk-你的DeepSeek密钥
BAILIAN_API_KEY=sk-你的百炼密钥

# ---------- 必填：MySQL 数据库密码 ----------
MYSQL_ROOT_PASSWORD=smartkb123

# ---------- 可选：服务端口 ----------
BACKEND_PORT=8080
FRONTEND_PORT=80
MYSQL_PORT=3306
REDIS_PORT=6379
